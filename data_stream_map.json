    },
    "algorithmic_sentiment_intercepts": {
      "type": "object",
      "properties": {
        "nlp_token_stream": {
          "type": "string",
          "default": "https://whipshaw.internal"
        },
        "target_manipulation_vectors": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["dealmaker", "master negotiator", "peace deal", "proceeding nicely", "market breakout"]
        }
      },
      "required": ["nlp_token_stream", "target_manipulation_vectors"]
    },
    "structural_market_metrics": {
      "type": "object",
      "properties": {
