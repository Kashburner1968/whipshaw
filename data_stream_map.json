          "type": "number",
          "description": "S&P Equal Weight vs Cap Weight divergence coefficient. Values below 0.30 signal predatory concentration decay."
        },
        "intraday_circuit_breakers": {
          "type": "array",
          "items": { "type": "number" },
          "default": [749.14, 744.49, 740.00]
        }
      },
      "required": ["market_breadth_ratio", "intraday_circuit_breakers"]
    }
